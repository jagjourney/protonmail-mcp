# Protonmail Bridge credentials
# These are NOT your regular Protonmail password.
# Get these from Protonmail Bridge app after setting it up.
# See: https://proton.me/mail/bridge
PROTONMAIL_USER=your-protonmail-email@proton.me
PROTONMAIL_PASS=your-bridge-password-here

# IMAP settings (Protonmail Bridge defaults)
PROTONMAIL_IMAP_HOST=127.0.0.1
PROTONMAIL_IMAP_PORT=1143
PROTONMAIL_IMAP_SECURE=false

# SMTP settings (Protonmail Bridge defaults)
PROTONMAIL_SMTP_HOST=127.0.0.1
PROTONMAIL_SMTP_PORT=1026
PROTONMAIL_SMTP_SECURE=false

# Path to Protonmail Desktop App (auto-detected on Windows)
# PROTONMAIL_APP_PATH=C:\Users\YourUser\AppData\Local\proton_mail\Proton Mail.exe

# Data directory for templates, rules, and sync settings (default: ~/.protonmail-mcp)
# PROTONMAIL_DATA_DIR=C:\Users\YourUser\Documents\protonmail-data
